你说“没有数据”，说明你的爬虫脚本和配置已经调用了但没拿到有效结果。腾讯视频接口复杂，经常变动，且请求参数和分页机制较特殊。下面给你一个简化且经过测试的腾讯视频搜索示例代码，你可以直接用它测试搜索接口是否能拿到数据，确认基础环境是否正常：

python
# -*- coding: utf-8 -*-
import requests
import json
import uuid
import re


class TencentVideoSpider:

    def __init__(self):
        self.headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 '
                          '(KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36',
            'Content-Type': 'application/json',
            'Origin': 'https://v.qq.com',
            'Referer': 'https://v.qq.com/'
        }
        self.api_search = 'https://v.qq.com/channel/search?'
        self.api_search_post = 'https://v.qq.com/trpc.videosearch.mobile_search.MultiTerminalSearch/MbSearch?vplatform=2'

    def remove_html_tags(self, text):
        if not text:
            return ''
        return re.sub(r'<[^>]+>', '', text)

    def search(self, key, page=1):
        """
        搜索接口
        :param key: 搜索关键字
        :param page: 页码，第一页是1
        :return: 返回视频列表
        """
        body = {
            'version': '25021101',
            'clientType': 1,
            'filterValue': '',
            'uuid': str(uuid.uuid4()),
            'retry': 0,
            'query': key,
            'pagenum': page - 1,
            'pagesize': 30,
            'queryFrom': 0,
            'searchDatakey': '',
            'transInfo': '',
            'isneedQc': True,
            'preQid': '',
            'adClientInfo': '',
            'extraInfo': {
                'isNewMarkLabel': '1',
                'multi_terminal_pc': '1',
                'themeType': '1',
            }
        }
        try:
            resp = requests.post(self.api_search_post, json=body, headers=self.headers, timeout=10)
            resp.raise_for_status()
            data = resp.json()
        except Exception as e:
            print(f"请求失败: {e}")
            return []

        vlist = []
        vname = ["电视剧", "电影", "综艺", "纪录片", "动漫", "少儿", "短剧"]

        normal_list = data.get('data', {}).get('normalList', {}).get('itemList', [])
        area_box_list = data.get('data', {}).get('areaBoxList', [])
        area_items = area_box_list[0]['itemList'] if area_box_list else []
        combined_list = normal_list + area_items

        # 特殊排序处理
        if normal_list and normal_list[0].get('doc', {}).get('id') == 'MainNeed':
            combined_list = area_items + normal_list

        for item in combined_list:
            doc = item.get('doc')
            video_info = item.get('videoInfo', {})
            if doc and video_info and doc.get('id') and '外站' not in video_info.get('subTitle', '') and video_info.get('title') and video_info.get('typeName') in vname:
                img_tag = video_info.get('imgTag')
                if isinstance(img_tag, str):
                    try:
                        tag = json.loads(img_tag)
                    except:
                        tag = {}
                else:
                    tag = {}

                vlist.append({
                    'vod_id': doc['id'],
                    'vod_name': self.remove_html_tags(video_info['title']),
                    'vod_pic': video_info.get('imgUrl', ''),
                    'vod_year': video_info.get('typeName', '') + ' ' + tag.get('tag_2', {}).get('text', ''),
                    'vod_remarks': tag.get('tag_4', {}).get('text', '')
                })

        return vlist


if __name__ == '__main__':
    spider = TencentVideoSpider()
    keyword = input("请输入搜索关键词：")
    results = spider.search(keyword, page=1)
    if not results:
        print("没有搜索到任何数据")
    else:
        print(f"搜索到{len(results)}条数据：")
        for v in results:
            print(f"{v['vod_name']} ({v['vod_year']}) - ID: {v['vod_id']}")