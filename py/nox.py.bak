# -*- coding:utf-8 -*-
import requests

class Spider:

    def init(self, extend=""):
        self.host = "http://110.42.3.227:12356"

    # ================= 首页 =================
    def homeContent(self, filter):
        return {
            "class": [
                {"type_name": "随看", "type_id": "2"}
            ]
        }

    # ================= 分类 =================
    def categoryContent(self, tid, pg, filter, extend):

        url = f"{self.host}/xiaohuangren.php"

        res = requests.post(url, json={})
        data = res.json()

        return data  # 接口本身就是TVBox格式

    # ================= 详情 =================
    def detailContent(self, ids):

        url = f"{self.host}/xiaohuangren.php"

        res = requests.post(url, json={"id": ids[0]})
        data = res.json()

        return data

    # ================= 播放 =================
    def playerContent(self, flag, id, vipFlags):

        try:
            # 👉 分离ID
            real_id = id.split("|")[0]

            # ================= NSYS =================
            if real_id.startswith("NSYS-"):

                file_id = real_id.replace("NSYS-", "")

                play_url = f"https://vip.nsapi.sbs/nsys/proxy.php?file={file_id}.m3u8"

                return {
                    "parse": 0,
                    "url": play_url,
                    "header": {
                        "User-Agent": "Mozilla/5.0"
                    }
                }

            # ================= NBY =================
            elif real_id.startswith("NBY-"):

                # 直接拼接口（你日志里已暴露 key）
                key = id.split("|")[1] if "|" in id else ""

                play_url = f"https://vip.nsapi.sbs/nby/api.php?id={real_id}&key={key}"

                return {
                    "parse": 0,
                    "url": play_url
                }

            # ================= rose =================
            elif real_id.startswith("rose_"):

                # URL编码已经带好
                play_url = f"https://vip.nsapi.sbs/rose/api.php?id={real_id}"

                return {
                    "parse": 0,
                    "url": play_url
                }

        except Exception as e:
            print("播放解析错误:", e)

        return {"parse": 1, "url": ""}