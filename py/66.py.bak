# 工具函数：发送网络请求
def request_url(url, headers=None):
    if headers is None:
        headers = RULE["headers"]
    try:
        resp = requests.get(url, headers=headers, timeout=RULE["timeout"]/1000)
        resp.encoding = RULE["encoding"]
        return resp.text
    except Exception as e:
        print(f"请求失败: {e}")
        return ""

# 工具函数：解析HTML元素文本或属性
def pdfh(soup, selector, attr="text"):
    """
    :param soup: BeautifulSoup对象
    :param selector: CSS选择器
    :param attr: 要获取的属性，text为文本
    :return: 解析结果
    """
    try:
        elem = soup.select_one(selector)
        if not elem:
            return ""
        if attr == "text":
            return elem.get_text(strip=True)
        return elem.get(attr, "")
    except:
        return ""

# 工具函数：解析HTML元素列表
def pdfa(soup, selector):
    try:
        return soup.select(selector)
    except:
        return []

# 工具函数：补全相对链接
def pd(url, base_url=RULE["host"]):
    if url.startswith("http"):
        return url
    return f"{base_url}{url}" if url.startswith("/") else f"{base_url}/{url}"

# 解析播放地址
def play_parse(play_url):
    html = request_url(play_url)
    if not html:
        return ""
    match = re.search(r'src="/player/mui-player\.php\?([^"]*)"', html)
    if not match:
        return play_url
    kcode = match.group(1)
    kurl = kcode.split(",")[1] if len(kcode.split(","))>1 else ""
    if kurl and (".m3u8" in kurl or ".mp4" in kurl):
        return kurl
    return play_url

# 搜索功能
def search(keyword):
    search_url = RULE["host"] + RULE["searchUrl"].format(keyword)
    html = request_url(search_url)
    if not html:
        return []
    soup = BeautifulSoup(html, "html.parser")
    items = pdfa(soup, ".hl-item-div")
    results = []
    for item in items:
        title = pdfh(item, "a", "title")
        cover = pdfh(item, "a", "data-original")
        remark = pdfh(item, ".hl-lc-1.remarks")
        href = pdfh(item, "a", "href")
        if title and href:
            results.append({
                "title": title,
                "cover": pd(cover),
                "remark": remark,
                "url": pd(href)
            })
    return results

# 解析详情页
def parse_detail(detail_url):
    html = request_url(detail_url)
    if not html:
        return {}
    soup = BeautifulSoup(html, "html.parser")
    vod = {}
    vod["vod_id"] = detail_url.split("/")[-1].split(".")[0] if "/" in detail_url else ""
    vod["vod_name"] = pdfh(soup, "h2")
    vod["type_name"] = pdfh(soup, 'li:contains("类型：")').replace("类型：", "").replace("/", "")
    vod["vod_pic"] = pd(pdfh(soup, "a", "data-original"))
    vod["vod_remarks"] = pdfh(soup, 'li:contains("状态：")')
    vod["vod_year"] = ""
    vod["vod_area"] = ""
    vod["vod_director"] = pdfh(soup, 'li:contains("导演")').replace("导演：", "")
    vod["vod_actor"] = pdfh(soup, 'li:contains("主演")').replace("主演：", "")
    vod["vod_content"] = pdfh(soup, ".hl-col-xs-12.blurb").replace("简介：", "")

    # 解析播放线路
    tabs = pdfa(soup, ".hl-plays-from.hl-tabs a")
    vod["vod_play_from"] = "$$$".join([pdfh(t, "text") for t in tabs])

    # 解析播放集数
    play_lists = pdfa(soup, ".hl-plays-list")
    klists = []
    for pl in play_lists:
        links = pdfa(pl, "a")
        klist = []
        for link in links:
            text = pdfh(link, "text")
            href = pdfh(link, "href")
            if "APP播放" not in text:
                klist.append(f"{text}${pd(href)}")
        klists.append("#".join(klist))
    vod["vod_play_url"] = "$$$".join(klists)
    return vod

# 测试代码
if __name__ == "__main__":
    # 1. 测试搜索
    keyword = "流浪地球"
    print(f"正在搜索: {keyword}")
    search_res = search(keyword)
    for idx, item in enumerate(search_res, 1):
        print(f"{idx}. 标题: {item['title']} | 链接: {item['url']}")
    
    # 2. 测试解析详情页（取搜索结果第一个）
    if search_res:
        print("\n正在解析详情页...")
        detail_res = parse_detail(search_res[0]["url"])
        print(f"影片名称: {detail_res['vod_name']}")
        print(f"导演: {detail_res['vod_director']}")
        print(f"主演: {detail_res['vod_actor']}")
        print(f"简介: {detail_res['vod_content']}")
        print(f"播放线路: {detail_res['vod_play_from']}")
